{
  "name": "polymarket-watch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
    "test": "tsx scripts/test.mts",
    "typecheck": "tsc --noEmit",
    "build": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@127.0.0.1:5432/polymarket_watch?schema=public} SKIP_TITLE_AI=1 prisma generate && SKIP_TITLE_AI=1 next build",
    "build:pages": "node scripts/build-pages.mjs",
    "dev:remote": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:paper": "node scripts/run-all.mjs",
    "dev:stable": "APP_PORT=3001 node scripts/run-all.mjs",
    "start:paper": "PAPER_PRODUCTION=1 node scripts/run-all.mjs",
    "db:push": "prisma db push",
    "db:migrate": "prisma db push",
    "backtest": "tsx scripts/run-backtest.mts",
    "backtest:export": "tsx scripts/export-model-evaluations.mts",
    "analyze:short-term": "tsx scripts/analyze-short-term-transfer.mts",
    "backtest:short-term-history": "tsx scripts/backtest-short-term-history.mts",
    "backtest:short-term-realtime": "tsx scripts/backtest-realtime-short-term.mts",
    "backtest:wallets": "tsx scripts/backtest-wallet-copy.mts",
    "backtest:hyperliquid": "HYPERLIQUID_MODEL_ONCE=1 tsx scripts/run-hyperliquid-model.mts",
    "collect:wallets": "WALLET_INTELLIGENCE_ONCE=1 tsx scripts/run-wallet-intelligence.mts",
    "backtest:short-term-worker": "tsx scripts/run-short-term-research.mts",
    "paper:backtest": "tsx scripts/run-paper-backtest.mts",
    "collect:crypto": "tsx scripts/collect-crypto-snapshots.mts",
    "collect:realtime": "tsx scripts/run-realtime-market-data.mts",
    "monitor": "tsx scripts/run-monitoring.mts",
    "mlflow:import": "MLFLOW_TRACKING_URI=sqlite:///$HOME/.polymarket-watch/mlflow.db $HOME/.polymarket-watch/mlflow-venv/bin/python scripts/import-model-evaluations-mlflow.py",
    "mlflow:service:install": "node scripts/install-mlflow-service.mjs",
    "mlflow:service:uninstall": "node scripts/install-mlflow-service.mjs --uninstall",
    "analytics:install": "node scripts/install-analytics-runtime.mjs",
    "archive:realtime": "ONCE=1 tsx scripts/run-columnar-archive.mts",
    "archive:query": "$HOME/.polymarket-watch/analytics-venv/bin/python scripts/query-realtime-archive.py",
    "db:recover": "node scripts/recover-runtime-database.mjs",
    "db:recover:apply": "node scripts/recover-runtime-database.mjs --apply",
    "db:postgres:install": "node scripts/install-postgres-service.mjs",
    "db:postgres:migrate": "python3 scripts/migrate-sqlite-to-postgres.py",
    "service:install": "node scripts/install-macos-service.mjs",
    "service:uninstall": "node scripts/install-macos-service.mjs --uninstall",
    "paper:trade": "tsx scripts/run-paper-trading.mts"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@radix-ui/react-slot": "1.1.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.468.0",
    "next": "15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "2.15.0",
    "tailwind-merge": "2.6.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.19",
    "postcss": "8.5.15",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.17",
    "tsx": "^4.22.4",
    "typescript": "5.7.2"
  }
}
