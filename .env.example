DATABASE_URL="file:./dev.db"

# Optional. e-Stat is disabled when this is empty.
E_STAT_APP_ID=""

DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-flash"

# Remote GitHub Pages demo bridge.
# Keep the default GitHub Pages origin allowed, add a custom domain if needed.
CORS_ALLOWED_ORIGINS="https://runnnnnnnnnnnnnnnnn.github.io,https://runnnnnnnn.github.io,http://localhost:3000,http://127.0.0.1:3000"
API_ACCESS_TOKEN="generate-a-long-random-token"

# Optional default API bridge URL embedded into a static Pages build.
# Usually leave empty and pass ?api=https://your-tunnel-url in the shared demo link.
NEXT_PUBLIC_LOCAL_API_BASE=""

# Optional Hyperliquid testnet connector. Mainnet execution is not supported.
# Use a dedicated API wallet private key, never a main wallet private key.
HYPERLIQUID_TESTNET_ENABLED="0"
HYPERLIQUID_TESTNET_AUTO_MIRROR="0"
HYPERLIQUID_ACCOUNT_ADDRESS=""
HYPERLIQUID_API_WALLET_PRIVATE_KEY=""
HYPERLIQUID_TESTNET_MAX_NOTIONAL_USD="25"

# Combined Polymarket -> Hyperliquid shadow strategy.
COMBINED_INITIAL_EQUITY="10000"
COMBINED_MINIMUM_SIGNAL_Z="0.5"
COMBINED_MAX_NOTIONAL="1000"
COMBINED_MAX_DAILY_LOSS_PCT="0.02"
COMBINED_MAX_DRAWDOWN_PCT="0.05"
COMBINED_KILL_SWITCH="0"
