generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WatchlistItem {
  id        String   @id
  marketId  String
  title     String
  category  String
  createdAt DateTime @default(now())

  @@index([marketId])
}

model MarketSnapshot {
  id          String   @id
  marketId    String
  probability Float
  yesPrice    Float
  noPrice     Float
  volume      Float
  liquidity   Float
  capturedAt  DateTime @default(now())

  @@index([marketId, capturedAt])
}
