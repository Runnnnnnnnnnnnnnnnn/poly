generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WatchlistItem {
  id        String   @id
  marketId  String
  title     String
  category  String
  createdAt DateTime @default(now())

  @@index([marketId])
}

model MarketSnapshot {
  id          String   @id
  marketId    String
  probability Float
  yesPrice    Float
  noPrice     Float
  volume      Float
  liquidity   Float
  capturedAt  DateTime @default(now())

  @@index([marketId, capturedAt])
}

model HyperliquidSnapshot {
  id               String   @id
  asset            String
  midPrice         Float
  markPrice        Float
  oraclePrice      Float
  previousDayPrice Float
  dayVolume        Float
  openInterest     Float
  fundingRate      Float
  capturedAt       DateTime @default(now())

  @@index([asset, capturedAt])
  @@index([capturedAt])
}

model PipelineHeartbeat {
  id            String    @id
  status        String
  records       Int       @default(0)
  message       String?
  lastAttemptAt DateTime
  lastSuccessAt DateTime?
  updatedAt     DateTime  @updatedAt
}

model ModelEvaluationRun {
  id           String    @id
  modelVersion String
  status       String
  datasetHash  String?
  configJson   String
  metricsJson  String?
  error        String?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  @@index([status, completedAt])
}

model PredictionMarket {
  id          String    @id
  asset       String
  tokenId     String
  title       String
  slug        String?
  endDate     DateTime?
  resolved    Boolean   @default(false)
  result      Int?
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())

  @@index([asset, endDate])
  @@index([resolved, endDate])
}

model BacktestRun {
  id             String          @id
  asset          String
  status         String
  threshold      Float
  initialCapital Float
  marketCount    Int             @default(0)
  metricsJson    String?
  error          String?
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  points         BacktestPoint[]
}

model BacktestPoint {
  id                   String      @id
  runId                String
  marketId             String
  observedAt           DateTime
  predictedProbability Float
  actualOutcome        Int
  brierScore           Float
  logLoss              Float
  position             Int
  pnl                  Float
  run                  BacktestRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, observedAt])
  @@index([marketId, observedAt])
}

model AiEvaluationSnapshot {
  id                String   @id
  marketId          String
  tabId             String
  tabLabel          String
  title             String
  marketProbability Float
  aiProbability     Float
  expectedReturnYes Float?
  expectedReturnNo  Float?
  rating            String
  confidence        String
  model             String
  status            String
  reasonsJson       String
  evidenceJson      String
  evaluatedAt       DateTime
  recordedAt        DateTime @default(now())
  resolvedOutcome   Int?
  brierScore        Float?

  @@index([marketId, recordedAt])
  @@index([evaluatedAt])
  @@index([status, recordedAt])
}

model PaperAccount {
  id          String            @id
  name        String
  initialCash Float
  cashBalance Float
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  runs        PaperTradingRun[]
}

model PaperTradingRun {
  id              String                @id
  accountId       String
  asset           String
  mode            String
  strategy        String
  status          String
  initialCash     Float
  finalCash       Float?
  configJson      String
  metricsJson     String?
  error           String?
  startedAt       DateTime              @default(now())
  completedAt     DateTime?
  account         PaperAccount          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  orders          PaperOrder[]
  fills           PaperFill[]           @relation("PaperRunFills")
  positions       PaperPosition[]
  equitySnapshots PaperEquitySnapshot[]

  @@index([accountId, startedAt])
  @@index([asset, mode, status])
}

model PaperOrder {
  id                String          @id
  runId             String
  marketId          String
  tokenId           String
  outcome           String
  side              String
  orderType         String
  requestedPrice    Float
  requestedQuantity Float
  filledPrice       Float?
  filledQuantity    Float           @default(0)
  fee               Float           @default(0)
  slippage          Float           @default(0)
  status            String
  reason            String?
  submittedAt       DateTime        @default(now())
  filledAt          DateTime?
  run               PaperTradingRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  fills             PaperFill[]

  @@index([runId, submittedAt])
  @@index([marketId, status])
}

model PaperFill {
  id       String          @id
  runId    String
  orderId  String
  marketId String
  tokenId  String
  outcome  String
  side     String
  price    Float
  quantity Float
  notional Float
  fee      Float
  slippage Float
  filledAt DateTime        @default(now())
  run      PaperTradingRun @relation("PaperRunFills", fields: [runId], references: [id], onDelete: Cascade)
  order    PaperOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([runId, filledAt])
  @@index([marketId, filledAt])
}

model PaperPosition {
  id              String          @id
  runId           String
  marketId        String
  tokenId         String
  outcome         String
  quantity        Float
  avgEntryPrice   Float
  costBasis       Float
  feePaid         Float           @default(0)
  settlementValue Float?
  realizedPnl     Float?
  status          String
  openedAt        DateTime        @default(now())
  closedAt        DateTime?
  run             PaperTradingRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, marketId, outcome])
  @@index([runId, status])
}

model PaperEquitySnapshot {
  id             String          @id
  runId          String
  capturedAt     DateTime        @default(now())
  cash           Float
  positionsValue Float
  equity         Float
  unrealizedPnl  Float
  run            PaperTradingRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, capturedAt])
}

model CombinedShadowRun {
  id               String                         @id
  status           String
  initialEquity    Float
  cash             Float
  equity           Float
  peakEquity       Float
  maxDrawdownPct   Float                          @default(0)
  realizedPnl      Float                          @default(0)
  riskStatus       String                         @default("NORMAL")
  emergencyStopped Boolean                        @default(false)
  configJson       String
  lastDecisionJson String?
  startedAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt
  stoppedAt        DateTime?
  positions        CombinedShadowPosition[]
  decisions        CombinedShadowDecision[]
  snapshots        CombinedShadowEquitySnapshot[]
  orders           CombinedExecutionOrder[]

  @@index([status, startedAt])
}

model CombinedShadowPosition {
  id             String                   @id
  runId          String
  eventId        String
  marketId       String
  asset          String
  side           String
  quantity       Float
  entryPrice     Float
  markPrice      Float
  impliedTarget  Float
  signalZ        Float
  horizonHours   Int?
  priceBasisPct  Float?
  entryFee       Float
  accruedFunding Float                    @default(0)
  realizedPnl    Float?
  status         String
  openedAt       DateTime                 @default(now())
  exitAt         DateTime
  closedAt       DateTime?
  closeReason    String?
  run            CombinedShadowRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  orders         CombinedExecutionOrder[]

  @@index([runId, status])
  @@index([eventId, asset])
}

model CombinedShadowDecision {
  id          String            @id
  runId       String
  eventId     String?
  marketId    String?
  asset       String?
  action      String
  reason      String
  probability Float?
  spotPrice   Float?
  targetPrice Float?
  signalZ     Float?
  threshold   Float
  horizonHours            Int?
  scannedMarkets          Int       @default(0)
  structuredMarkets       Int       @default(0)
  horizonEligibleMarkets  Int       @default(0)
  groupedEvents           Int       @default(0)
  priceReadyEvents        Int       @default(0)
  marketBestBid           Float?
  marketBestAsk           Float?
  marketSpread            Float?
  polymarketReferencePrice Float?
  referenceSource         String?
  priceBasisPct           Float?
  ladderViolations        Int?
  nextWindowAt            DateTime?
  observedAt  DateTime          @default(now())
  run         CombinedShadowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, observedAt])
  @@index([action, observedAt])
  @@index([horizonHours, observedAt])
}

model CombinedShadowEquitySnapshot {
  id             String            @id
  runId          String
  cash           Float
  positionsPnl   Float
  equity         Float
  drawdownPct    Float
  dailyReturnPct Float
  capturedAt     DateTime          @default(now())
  run            CombinedShadowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, capturedAt])
}

model CombinedExecutionOrder {
  id             String                  @id
  runId          String
  positionId     String?
  environment    String
  clientOrderId  String                  @unique
  asset          String
  side           String
  action         String
  quantity       Float
  referencePrice Float?
  status         String
  reason         String?
  responseJson   String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  run            CombinedShadowRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
  position       CombinedShadowPosition? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@index([runId, createdAt])
  @@index([environment, status])
}
