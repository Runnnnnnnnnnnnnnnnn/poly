generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WatchlistItem {
  id        String   @id
  marketId  String
  title     String
  category  String
  createdAt DateTime @default(now())

  @@index([marketId])
}

model MarketSnapshot {
  id                     String    @id
  marketId               String
  probability            Float
  yesPrice               Float
  noPrice                Float
  volume                 Float
  liquidity              Float
  bestBid                Float?
  bestAsk                Float?
  spread                 Float?
  clobCapturedAt         DateTime?
  clobUpdatedAt          DateTime?
  hyperliquidMidPrice    Float?
  hyperliquidMarkPrice   Float?
  hyperliquidOraclePrice Float?
  hyperliquidFundingRate Float?
  hyperliquidBestBid     Float?
  hyperliquidBestAsk     Float?
  hyperliquidSpread      Float?
  hyperliquidBookUpdatedAt DateTime?
  hyperliquidCapturedAt  DateTime?
  referencePrice         Float?
  referenceSource        String?
  referenceCapturedAt    DateTime?
  priceBasisPct          Float?
  captureSkewMs          Int?
  synchronizationVersion String?
  capturedAt             DateTime  @default(now())

  @@index([marketId, capturedAt])
  @@index([capturedAt, captureSkewMs])
  @@index([synchronizationVersion, capturedAt, captureSkewMs])
}

model HyperliquidSnapshot {
  id               String   @id
  asset            String
  midPrice         Float
  markPrice        Float
  oraclePrice      Float
  previousDayPrice Float
  dayVolume        Float
  openInterest     Float
  fundingRate      Float
  bestBid          Float?
  bestAsk          Float?
  spread           Float?
  bookUpdatedAt    DateTime?
  capturedAt       DateTime @default(now())

  @@index([asset, capturedAt])
  @@index([capturedAt])
}

model RealtimeMarketTick {
  id                           String   @id
  eventId                      String?
  marketId                     String
  positiveTokenId              String
  negativeTokenId              String
  asset                        String
  marketStartAt                DateTime
  marketEndAt                  DateTime
  marketPhase                  String
  probability                  Float
  polymarketBestBid            Float
  polymarketBestAsk            Float
  polymarketBidSize            Float?
  polymarketAskSize            Float?
  polymarketSpread             Float
  polymarketUpdatedAt          DateTime
  negativeBestBid              Float
  negativeBestAsk              Float
  negativeBidSize              Float?
  negativeAskSize              Float?
  negativeSpread               Float
  negativeUpdatedAt            DateTime
  hyperliquidBestBid           Float
  hyperliquidBestAsk           Float
  hyperliquidBidSize           Float?
  hyperliquidAskSize           Float?
  hyperliquidSpread            Float
  hyperliquidMidPrice          Float
  hyperliquidMarkPrice         Float?
  hyperliquidOraclePrice       Float?
  hyperliquidFundingRate       Float?
  hyperliquidUpdatedAt         DateTime
  chainlinkPrice               Float?
  chainlinkUpdatedAt           DateTime?
  binancePrice                 Float?
  binanceUpdatedAt             DateTime?
  referencePrice               Float
  referenceSource              String
  referenceUpdatedAt           DateTime
  priceBasisPct                Float
  complementBidSum             Float
  complementAskSum             Float
  arbitrageViolation           Boolean  @default(false)
  captureSkewMs                Int
  synchronizationVersion       String
  capturedAt                   DateTime @default(now())

  @@index([marketId, capturedAt])
  @@index([asset, capturedAt])
  @@index([capturedAt, captureSkewMs])
  @@index([synchronizationVersion, capturedAt])
}

model RealtimeAssetTick {
  id                     String   @id
  asset                  String
  hyperliquidBestBid     Float
  hyperliquidBestAsk     Float
  hyperliquidBidSize     Float?
  hyperliquidAskSize     Float?
  hyperliquidSpread      Float
  hyperliquidMidPrice    Float
  hyperliquidMarkPrice   Float?
  hyperliquidOraclePrice Float?
  hyperliquidFundingRate Float?
  hyperliquidUpdatedAt   DateTime
  chainlinkPrice         Float?
  chainlinkUpdatedAt     DateTime?
  binancePrice           Float?
  binanceUpdatedAt       DateTime?
  captureSkewMs          Int
  synchronizationVersion String
  capturedAt             DateTime @default(now())

  @@index([asset, capturedAt])
  @@index([capturedAt, captureSkewMs])
  @@index([synchronizationVersion, capturedAt])
}

model PipelineHeartbeat {
  id            String    @id
  status        String
  records       Int       @default(0)
  message       String?
  lastAttemptAt DateTime
  lastSuccessAt DateTime?
  updatedAt     DateTime  @updatedAt
}

model ModelEvaluationRun {
  id           String    @id
  modelVersion String
  status       String
  datasetHash  String?
  configJson   String
  metricsJson  String?
  error        String?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  @@index([status, completedAt])
}

model PredictionMarket {
  id          String    @id
  eventId     String?
  asset       String
  tokenId     String
  title       String
  slug        String?
  endDate     DateTime?
  resolved    Boolean   @default(false)
  result      Int?
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())

  @@index([asset, endDate])
  @@index([eventId, endDate])
  @@index([resolved, endDate])
}

model BacktestRun {
  id             String          @id
  asset          String
  status         String
  threshold      Float
  initialCapital Float
  marketCount    Int             @default(0)
  metricsJson    String?
  error          String?
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  points         BacktestPoint[]
}

model BacktestPoint {
  id                   String      @id
  runId                String
  marketId             String
  observedAt           DateTime
  predictedProbability Float
  actualOutcome        Int
  brierScore           Float
  logLoss              Float
  position             Int
  pnl                  Float
  run                  BacktestRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, observedAt])
  @@index([marketId, observedAt])
}

model AiEvaluationSnapshot {
  id                String   @id
  marketId          String
  tabId             String
  tabLabel          String
  title             String
  marketProbability Float
  aiProbability     Float
  expectedReturnYes Float?
  expectedReturnNo  Float?
  rating            String
  confidence        String
  model             String
  status            String
  reasonsJson       String
  evidenceJson      String
  evaluatedAt       DateTime
  recordedAt        DateTime @default(now())
  resolvedOutcome   Int?
  brierScore        Float?

  @@index([marketId, recordedAt])
  @@index([evaluatedAt])
  @@index([status, recordedAt])
}

model PaperAccount {
  id          String            @id
  name        String
  initialCash Float
  cashBalance Float
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  runs        PaperTradingRun[]
}

model PaperTradingRun {
  id              String                @id
  accountId       String
  asset           String
  mode            String
  strategy        String
  status          String
  initialCash     Float
  finalCash       Float?
  configJson      String
  metricsJson     String?
  error           String?
  startedAt       DateTime              @default(now())
  completedAt     DateTime?
  account         PaperAccount          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  orders          PaperOrder[]
  fills           PaperFill[]           @relation("PaperRunFills")
  positions       PaperPosition[]
  equitySnapshots PaperEquitySnapshot[]

  @@index([accountId, startedAt])
  @@index([asset, mode, status])
}

model PaperOrder {
  id                String          @id
  runId             String
  marketId          String
  tokenId           String
  outcome           String
  side              String
  orderType         String
  requestedPrice    Float
  requestedQuantity Float
  filledPrice       Float?
  filledQuantity    Float           @default(0)
  fee               Float           @default(0)
  slippage          Float           @default(0)
  status            String
  reason            String?
  submittedAt       DateTime        @default(now())
  filledAt          DateTime?
  run               PaperTradingRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  fills             PaperFill[]

  @@index([runId, submittedAt])
  @@index([marketId, status])
}

model PaperFill {
  id       String          @id
  runId    String
  orderId  String
  marketId String
  tokenId  String
  outcome  String
  side     String
  price    Float
  quantity Float
  notional Float
  fee      Float
  slippage Float
  filledAt DateTime        @default(now())
  run      PaperTradingRun @relation("PaperRunFills", fields: [runId], references: [id], onDelete: Cascade)
  order    PaperOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([runId, filledAt])
  @@index([marketId, filledAt])
}

model PaperPosition {
  id              String          @id
  runId           String
  marketId        String
  tokenId         String
  outcome         String
  quantity        Float
  avgEntryPrice   Float
  costBasis       Float
  feePaid         Float           @default(0)
  settlementValue Float?
  realizedPnl     Float?
  status          String
  openedAt        DateTime        @default(now())
  closedAt        DateTime?
  run             PaperTradingRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, marketId, outcome])
  @@index([runId, status])
}

model PaperEquitySnapshot {
  id             String          @id
  runId          String
  capturedAt     DateTime        @default(now())
  cash           Float
  positionsValue Float
  equity         Float
  unrealizedPnl  Float
  run            PaperTradingRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, capturedAt])
}

model CombinedShadowRun {
  id               String                         @id
  status           String
  initialEquity    Float
  cash             Float
  equity           Float
  peakEquity       Float
  maxDrawdownPct   Float                          @default(0)
  realizedPnl      Float                          @default(0)
  riskStatus       String                         @default("NORMAL")
  emergencyStopped Boolean                        @default(false)
  configJson       String
  lastDecisionJson String?
  startedAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt
  stoppedAt        DateTime?
  positions        CombinedShadowPosition[]
  decisions        CombinedShadowDecision[]
  snapshots        CombinedShadowEquitySnapshot[]
  orders           CombinedExecutionOrder[]

  @@index([status, startedAt])
}

model CombinedShadowPosition {
  id             String                   @id
  runId          String
  eventId        String
  marketId       String
  asset          String
  side           String
  quantity       Float
  entryPrice     Float
  markPrice      Float
  impliedTarget  Float
  signalZ        Float
  polymarketSide String?
  entrySpotPrice Float?
  entryTrendZ6h  Float?
  entryFunding24h Float?
  horizonHours   Int?
  priceBasisPct  Float?
  entryReferencePrice      Float?
  entryReferenceSource     String?
  entryReferenceCapturedAt DateTime?
  exitReferencePrice       Float?
  exitReferenceSource      String?
  exitReferenceCapturedAt  DateTime?
  exitPriceBasisPct         Float?
  entryFee       Float
  accruedFunding Float                    @default(0)
  realizedPnl    Float?
  status         String
  openedAt       DateTime                 @default(now())
  exitAt         DateTime
  closedAt       DateTime?
  closeReason    String?
  run            CombinedShadowRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  orders         CombinedExecutionOrder[]

  @@index([runId, status])
  @@index([eventId, asset])
}

model CombinedShadowDecision {
  id          String            @id
  runId       String
  eventId     String?
  marketId    String?
  asset       String?
  action      String
  reason      String
  probability Float?
  spotPrice   Float?
  targetPrice Float?
  signalZ     Float?
  polymarketSide String?
  strategySide String?
  trendZ6h Float?
  hyperliquidFunding24h Float?
  threshold   Float
  horizonHours            Int?
  scannedMarkets          Int       @default(0)
  structuredMarkets       Int       @default(0)
  horizonEligibleMarkets  Int       @default(0)
  groupedEvents           Int       @default(0)
  priceReadyEvents        Int       @default(0)
  marketBestBid           Float?
  marketBestAsk           Float?
  marketSpread            Float?
  polymarketReferencePrice Float?
  referenceSource         String?
  referenceCapturedAt     DateTime?
  priceBasisPct           Float?
  ladderViolations        Int?
  nextWindowAt            DateTime?
  observedAt  DateTime          @default(now())
  run         CombinedShadowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, observedAt])
  @@index([action, observedAt])
  @@index([horizonHours, observedAt])
}

model CombinedShadowEquitySnapshot {
  id             String            @id
  runId          String
  cash           Float
  positionsPnl   Float
  equity         Float
  drawdownPct    Float
  dailyReturnPct Float
  capturedAt     DateTime          @default(now())
  run            CombinedShadowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, capturedAt])
}

model CombinedExecutionOrder {
  id             String                  @id
  runId          String
  positionId     String?
  environment    String
  clientOrderId  String                  @unique
  exchangeOrderId String?
  exchangeStatus String?
  asset          String
  side           String
  action         String
  quantity       Float
  filledQuantity Float                   @default(0)
  averageFillPrice Float?
  feePaid        Float                   @default(0)
  referencePrice Float?
  status         String
  reason         String?
  responseJson   String?
  lastReconciledAt DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  run            CombinedShadowRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
  position       CombinedShadowPosition? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@index([runId, createdAt])
  @@index([environment, status])
  @@unique([positionId, environment, action])
}

model CombinedExecutionAccountSnapshot {
  id                   String   @id
  environment          String
  accountValue         Float
  accountLossPct       Float?
  openOrderCount       Int
  positionCount        Int
  orderMismatchCount   Int
  positionMismatchCount Int
  healthy              Boolean
  issuesJson           String
  capturedAt           DateTime @default(now())

  @@index([environment, capturedAt])
}

model HyperliquidTestnetVerificationRun {
  id                       String    @id
  status                   String
  asset                    String?
  requestedNotionalUsd     Float?
  sdkVersion               String?
  connectivityPassed       Boolean   @default(false)
  openFillPassed           Boolean   @default(false)
  closeFillPassed          Boolean   @default(false)
  restingOrderPassed       Boolean   @default(false)
  cancelPassed             Boolean   @default(false)
  deadManSwitchPassed      Boolean   @default(false)
  partialFillObserved      Boolean   @default(false)
  reconnectPassed          Boolean   @default(false)
  reconciliationPassed     Boolean   @default(false)
  emergencyCleanupPassed   Boolean   @default(false)
  orphanOrderCount         Int       @default(0)
  positionMismatchCount    Int       @default(0)
  resultJson               String?
  error                    String?
  startedAt                DateTime  @default(now())
  completedAt              DateTime?

  @@index([status, startedAt])
  @@index([completedAt])
}
